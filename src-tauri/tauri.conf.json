{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SiLibreKost-Admin",
  "version": "0.1.18",
  "identifier": "org.librekost.admin",
  "build": {
    "beforeBuildCommand": "npm run build:frontend",
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Si-LibreKost-Admin",
        "width": 800,
        "height": 600,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#1e1e2e"
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      },
      "csp": "default-src 'self' asset: https://asset.localhost tauri:; img-src 'self' asset: https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}